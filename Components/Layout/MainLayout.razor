@inherits LayoutComponentBase
@inject JourneyService Journey

<div class="app-shell">
    <header class="app-header">
        <div class="app-header__brand">
            <span class="app-header__name">Agentic SDLC Studio</span>
            <span class="app-header__tagline">
                What mature, agent-driven enterprise delivery actually looks like — one feature, end to end.
            </span>
        </div>
        <div class="app-header__ticket" title="@Journey.FeatureTitle">
            <span class="app-header__ticket-label">Ticket</span>
            <span class="app-header__ticket-value">@Journey.FeatureTitle</span>
        </div>
    </header>

    <div class="app-body">
        <aside class="app-rail">
            <ProgressRail />
            <nav class="rail-links" aria-label="Resources">
                <span class="rail-links__label">Take it further</span>
                <a class="rail-link" href="https://github.com/marvingarcia25/agentic-sdlc-reference"
                   target="_blank" rel="noopener noreferrer">
                    <span class="rail-link__icon">📦</span>
                    <span class="rail-link__text">
                        <span class="rail-link__title">Reference template</span>
                        <span class="rail-link__sub">Clone the runnable golden path</span>
                    </span>
                    <span class="rail-link__ext">↗</span>
                </a>
                <a class="rail-link" href="https://github.com/marvingarcia25/agentic-sdlc-scaffold"
                   target="_blank" rel="noopener noreferrer">
                    <span class="rail-link__icon">⚙️</span>
                    <span class="rail-link__text">
                        <span class="rail-link__title">Scaffold CLI</span>
                        <span class="rail-link__sub">Generate a compliant project</span>
                    </span>
                    <span class="rail-link__ext">↗</span>
                </a>
                <a class="rail-link" href="https://github.com/marvingarcia25/agentic-sdlc-studio"
                   target="_blank" rel="noopener noreferrer">
                    <span class="rail-link__icon">🧭</span>
                    <span class="rail-link__text">
                        <span class="rail-link__title">This showcase's source</span>
                        <span class="rail-link__sub">See how it's built</span>
                    </span>
                    <span class="rail-link__ext">↗</span>
                </a>
            </nav>
        </aside>
        <main class="app-main">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
